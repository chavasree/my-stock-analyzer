# ─────────────────────────────────────────────────────────────────────────────
# Sri's Stock Analyzer — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# 
# STEP 1: Copy this file and rename it to:  .env
#         (remove the .example part)
#
# STEP 2: Get your API key from:
#         https://console.anthropic.com/settings/keys
#
# STEP 3: Paste your key below (replace the placeholder)
#
# ─────────────────────────────────────────────────────────────────────────────

VITE_ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT SECURITY RULES:
# 1. NEVER commit the .env file to GitHub (it's already in .gitignore)
# 2. NEVER share your API key with anyone
# 3. On Vercel: add this key in Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
